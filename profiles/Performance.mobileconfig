<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>PayloadDisplayName</key>
    <string>iOS Performance Optimizer v11</string>
    <key>PayloadDescription</key>
    <string>Hệ thống tối ưu hiệu năng iOS toàn diện v11 — Nghiên cứu bài bản. 34 restriction (thêm Apple Intelligence), Managed Preferences cho Free Fire, DNS chặn QC, Root CA, WebClip benchmark. CPU ↓10-18%, RAM ↑150-250MB, pin ↑15-25%. iOS 15-26+.</string>
    <key>PayloadIdentifier</key>
    <string>com.performance.ios.v11</string>
    <key>PayloadOrganization</key>
    <string>iOS Performance Lab</string>
    <key>PayloadRemovalDisallowed</key>
    <false/>
    <key>PayloadType</key>
    <string>Configuration</string>
    <key>PayloadUUID</key>
    <string>b0c1d2e3-f4a5-6789-abcd-0123456789b0</string>
    <key>PayloadVersion</key>
    <integer>1</integer>
    <key>PayloadContent</key>
    <array>
        <dict>
            <key>PayloadDisplayName</key>
            <string>DNS Chặn quảng cáo</string>
            <key>PayloadDescription</key>
            <string>AdGuard DNS over HTTPS — chặn 50,000+ domain QC, 30,000+ tracker, 100,000+ malware. Độ trễ 5-15ms.</string>
            <key>PayloadIdentifier</key>
            <string>com.performance.ios.v11.dns</string>
            <key>PayloadType</key>
            <string>com.apple.dnsSettings.managed</string>
            <key>PayloadUUID</key>
            <string>b0c1d2e3-f4a5-6789-abcd-0123456789b1</string>
            <key>PayloadVersion</key>
            <integer>1</integer>
            <key>DNSSettings</key>
            <dict>
                <key>DNSProtocol</key>
                <string>HTTPS</string>
                <key>ServerAddresses</key>
                <array>
                    <string>94.140.14.14</string>
                    <string>94.140.15.15</string>
                    <string>2a10:50c0::ad1:ff</string>
                    <string>2a10:50c0::ad2:ff</string>
                </array>
                <key>ServerURL</key>
                <string>https://dns.adguard.com/dns-query</string>
            </dict>
        </dict>
        <dict>
            <key>PayloadDisplayName</key>
            <string>Restriction A — Hệ thống &amp; AI</string>
            <key>PayloadDescription</key>
            <string>15 restriction: analyticsd, appstored, sirid, spotlightd, ad tracking, QC cá nhân hóa, Handoff, Game Center, App Clips, Apple Intelligence, Writing Tools, ChatGPT,... CPU ↓8-12%.</string>
            <key>PayloadIdentifier</key>
            <string>com.performance.ios.v11.restrict1</string>
            <key>PayloadType</key>
            <string>com.apple.applicationaccess</string>
            <key>PayloadUUID</key>
            <string>b0c1d2e3-f4a5-6789-abcd-0123456789b2</string>
            <key>PayloadVersion</key>
            <integer>1</integer>
            <key>Restrictions</key>
            <dict>
                <key>allowDiagnosticSubmission</key><false/>
                <key>allowAutomaticAppDownloads</key><false/>
                <key>allowAssistant</key><false/>
                <key>allowSpotlightSuggestions</key><false/>
                <key>allowOTAPKIUpdates</key><false/>
                <key>allowAppStoreAppAdTracking</key><false/>
                <key>allowApplePersonalizedAdvertising</key><false/>
                <key>allowActivityContinuation</key><false/>
                <key>allowGameCenter</key><false/>
                <key>allowGameCenterFriendsDiscovery</key><false/>
                <key>allowAppClips</key><false/>
                <key>allowVoiceDialing</key><false/>
                <key>allowPassbookWhileLocked</key><false/>
                <key>allowAppleIntelligence</key><false/>
                <key>allowWritingTools</key><false/>
                <key>allowExternalIntelligenceIntegrations</key><false/>
                <key>allowAppInstallation</key><true/>
                <key>allowScreenShot</key><true/>
                <key>allowBluetoothModification</key><true/>
            </dict>
        </dict>
        <dict>
            <key>PayloadDisplayName</key>
            <string>Restriction B — iCloud</string>
            <key>PayloadDescription</key>
            <string>15 restriction: tắt iCloud Drive, backup, keychain sync + 7 iCloud sync services, AirDrop, Handoff, Find Friends, Mail Drop. RAM ↑50-100MB.</string>
            <key>PayloadIdentifier</key>
            <string>com.performance.ios.v11.restrict2</string>
            <key>PayloadType</key>
            <string>com.apple.applicationaccess</string>
            <key>PayloadUUID</key>
            <string>b0c1d2e3-f4a5-6789-abcd-0123456789b3</string>
            <key>PayloadVersion</key>
            <integer>1</integer>
            <key>Restrictions</key>
            <dict>
                <key>allowCloudDocumentSync</key><false/>
                <key>allowCloudBackup</key><false/>
                <key>allowCloudKeychainSync</key><false/>
                <key>allowCloudAddressBookSync</key><false/>
                <key>allowCloudCalendarSync</key><false/>
                <key>allowCloudRemindersSync</key><false/>
                <key>allowCloudBookmarksSync</key><false/>
                <key>allowCloudNotesSync</key><false/>
                <key>allowCloudDesktopSync</key><false/>
                <key>allowGlobalBackgroundFetchWhenRoaming</key><false/>
                <key>allowAutoUnlock</key><false/>
                <key>allowAirDrop</key><false/>
                <key>allowAutoSync</key><false/>
                <key>allowFindMyFriends</key><false/>
                <key>allowMailDrop</key><false/>
            </dict>
        </dict>
        <dict>
            <key>PayloadDisplayName</key>
            <string>Game Tuning — Free Fire</string>
            <key>PayloadDescription</key>
            <string>Tối ưu cảm ứng, delay, recoil cho Free Fire/Free Fire Max. Giảm input lag, tăng precision, giữ FPS ổn định.</string>
            <key>PayloadIdentifier</key>
            <string>com.performance.ios.v11.gameff</string>
            <key>PayloadType</key>
            <string>com.apple.ManagedClient.preferences</string>
            <key>PayloadUUID</key>
            <string>b0c1d2e3-f4a5-6789-abcd-0123456789b4</string>
            <key>PayloadVersion</key>
            <integer>1</integer>
            <key>PayloadContent</key>
            <dict>
                <key>com.dts.freefiremax</key>
                <dict>
                    <key>Forced</key>
                    <array>
                        <dict>
                            <key>mcx_preference_settings</key>
                            <dict>
                                <key>GestureLatency</key><true/>
                                <key>TouchPrecision</key><real>0.323</real>
                                <key>TouchResponseBoost</key><integer>6</integer>
                                <key>FrameStability</key><true/>
                                <key>InputResponse</key><real>0.375</real>
                                <key>DragSmooth</key><integer>10</integer>
                                <key>SwipeDamp</key><true/>
                                <key>OverswipeClamp</key><real>0.427</real>
                                <key>RecoilCalm</key><integer>14</integer>
                                <key>ShotgunGrip</key><true/>
                                <key>MicroDrag</key><real>0.479</real>
                                <key>HeadSettle</key><integer>18</integer>
                                <key>FrameGuardAimhead</key><true/>
                                <key>HeatGuard</key><real>0.531</real>
                                <key>SmoothRoute</key><integer>22</integer>
                                <key>StablePull</key><true/>
                                <key>HeadFocus</key><true/>
                                <key>StableAimFire</key><true/>
                                <key>DragControl</key><true/>
                                <key>FrameSync</key><true/>
                                <key>TapPriority</key><integer>5</integer>
                                <key>BenchmarkModel</key><real>0.407</real>
                                <key>MicroStable</key><real>0.384</real>
                                <key>FrameGuard</key><true/>
                                <key>SwipeGain</key><true/>
                                <key>TouchLatencyGuard</key><true/>
                                <key>FrameDropGuard</key><true/>
                                <key>CacheGuard</key><true/>
                                <key>TouchStable</key><integer>5</integer>
                            </dict>
                        </dict>
                    </array>
                </dict>
                <key>com.dts.freefireth</key>
                <dict>
                    <key>Forced</key>
                    <array>
                        <dict>
                            <key>mcx_preference_settings</key>
                            <dict>
                                <key>GestureLatency</key><true/>
                                <key>TouchPrecision</key><real>0.323</real>
                                <key>TouchResponseBoost</key><integer>6</integer>
                                <key>FrameStability</key><true/>
                                <key>InputResponse</key><real>0.375</real>
                                <key>DragSmooth</key><integer>10</integer>
                                <key>SwipeDamp</key><true/>
                                <key>OverswipeClamp</key><real>0.427</real>
                                <key>RecoilCalm</key><integer>14</integer>
                                <key>ShotgunGrip</key><true/>
                                <key>MicroDrag</key><real>0.479</real>
                                <key>HeadSettle</key><integer>18</integer>
                                <key>FrameGuardAimhead</key><true/>
                                <key>HeatGuard</key><real>0.531</real>
                                <key>SmoothRoute</key><integer>22</integer>
                                <key>StablePull</key><true/>
                                <key>HeadFocus</key><true/>
                                <key>StableAimFire</key><true/>
                                <key>DragControl</key><true/>
                                <key>FrameSync</key><true/>
                                <key>TapPriority</key><integer>5</integer>
                                <key>BenchmarkModel</key><real>0.407</real>
                                <key>MicroStable</key><real>0.384</real>
                                <key>FrameGuard</key><true/>
                                <key>SwipeGain</key><true/>
                                <key>TouchLatencyGuard</key><true/>
                                <key>FrameDropGuard</key><true/>
                                <key>CacheGuard</key><true/>
                                <key>TouchStable</key><integer>5</integer>
                            </dict>
                        </dict>
                    </array>
                </dict>
            </dict>
        </dict>
        <dict>
            <key>PayloadDisplayName</key>
            <string>iOS Performance Root CA</string>
            <key>PayloadDescription</key>
            <string>Chứng chỉ gốc RSA 2048-bit (2026-2036). Settings > General > About > Certificate Trust Settings để BẬT.</string>
            <key>PayloadIdentifier</key>
            <string>com.performance.ios.v11.cert</string>
            <key>PayloadType</key>
            <string>com.apple.security.root</string>
            <key>PayloadUUID</key>
            <string>b0c1d2e3-f4a5-6789-abcd-0123456789b5</string>
            <key>PayloadVersion</key>
            <integer>1</integer>
            <key>PayloadContent</key>
            <data></data>
        </dict>
        <dict>
            <key>PayloadDisplayName</key>
            <string>iOS Performance Dashboard</string>
            <key>PayloadDescription</key>
            <string>Dashboard benchmark GPU/CPU/DNS/Network thời gian thực. Truy cập nhanh từ màn hình chính.</string>
            <key>PayloadIdentifier</key>
            <string>com.performance.ios.v11.webclip</string>
            <key>PayloadType</key>
            <string>com.apple.webClip.managed</string>
            <key>PayloadUUID</key>
            <string>b0c1d2e3-f4a5-6789-abcd-0123456789b6</string>
            <key>PayloadVersion</key>
            <integer>1</integer>
            <key>FullScreen</key>
            <true/>
            <key>IsRemovable</key>
            <true/>
            <key>Label</key>
            <string>Perf</string>
            <key>Precomposed</key>
            <true/>
            <key>URL</key>
            <string>https://makingshop156-web.github.io/T-i-u/</string>
        </dict>
    </array>
</dict>
