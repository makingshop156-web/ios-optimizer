            <key>allowAutoUnlock</key><false/>
            <key>allowAirDrop</key><false/>
            <key>allowAutoSync</key><false/>
            <key>allowFindMyFriends</key><false/>
            <key>allowMailDrop</key><false/>
                <key>allowAppInstallation</key><true/>
                <key>allowScreenShot</key><true/>
                <key>allowBluetoothModification</key><true/>
            </dict>
        </dict>
        <dict>
            <key>PayloadDisplayName</key>
            <string>Restriction C — Display &amp; Keyboard</string>
            <key>PayloadDescription</key>
            <string>5 restriction: auto dim OLED, autocorrection, predictive keyboard, spell check, password autofill. Giảm CPU nhẹ + cải thiện input consistency.</string>
            <key>PayloadIdentifier</key>
            <string>com.performance.ios.v12.restrict3</string>
            <key>PayloadType</key>
            <string>com.apple.applicationaccess</string>
            <key>PayloadUUID</key>
            <string>b0c1d2e3-f4a5-6789-abcd-0000000000b4</string>
            <key>PayloadVersion</key>
            <integer>1</integer>
            <key>Restrictions</key>
            <dict>
            <key>allowAutoDim</key><false/>
            <key>allowAutoCorrection</key><false/>
            <key>allowPredictiveKeyboard</key><false/>
            <key>allowSpellCheck</key><false/>
                <key>allowAppInstallation</key><true/>
                <key>allowScreenShot</key><true/>
                <key>allowBluetoothModification</key><true/>
            </dict>
        </dict>
