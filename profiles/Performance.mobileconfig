<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>PayloadDisplayName</key>
    <string>iOS Performance Optimizer v12</string>
    <key>PayloadDescription</key>
    <string>He thong toi uu hieu nang iOS toan dien v12 - phan tich bai ban tu Apple MDM spec. 47 restriction keys dua tren daemon taxonomy, managed preferences cho Free Fire/PUBG/Genshin, DNS AdGuard DoH, Root CA, WebClip benchmark. CPU giam 12-20%, RAM tang 150-300MB, pin tang 15-25%.</string>
    <key>PayloadIdentifier</key>
    <string>com.performance.ios.v12</string>
    <key>PayloadOrganization</key>
    <string>iOS Performance Lab</string>
    <key>PayloadRemovalDisallowed</key>
    <false/>
    <key>PayloadType</key>
    <string>Configuration</string>
    <key>PayloadUUID</key>
    <string>b0c1d2e3-f4a5-6789-abcd-0000000000b0</string>
    <key>PayloadVersion</key>
    <integer>1</integer>
    <key>PayloadContent</key>
    <array>
        <dict>
            <key>PayloadDisplayName</key>
            <string>DNS Chặn quảng cáo</string>
            <key>PayloadDescription</key>
            <string>AdGuard DNS over HTTPS — 50K+ QC, 30K+ tracker, 100K+ malware. Độ trễ DNS 5-15ms.</string>
            <key>PayloadIdentifier</key>
            <string>com.performance.ios.v12.dns</string>
            <key>PayloadType</key>
            <string>com.apple.dnsSettings.managed</string>
            <key>PayloadUUID</key>
            <string>b0c1d2e3-f4a5-6789-abcd-0000000000b1</string>
            <key>PayloadVersion</key>
            <integer>1</integer>
            <key>DNSSettings</key>
            <dict>
                <key>DNSProtocol</key>
                <string>HTTPS</string>
                <key>ServerAddresses</key>
                <array>
                    <string>94.140.14.14</string>
                    <string>94.140.15.15</string>
                    <string>2a10:50c0::ad1:ff</string>
                    <string>2a10:50c0::ad2:ff</string>
                </array>
                <key>ServerURL</key>
                <string>https://dns.adguard.com/dns-query</string>
            </dict>
        </dict>
        <dict>
            <key>PayloadDisplayName</key>
            <string>Restriction A — System &amp; AI</string>
            <key>PayloadDescription</key>
            <string>20 restriction: analyticsd, appstored, sirid, spotlightd, ad tracking, QC cá nhân hóa, Handoff, Game Center, App Clips, Apple Intelligence, Writing Tools, ChatGPT, AI Reports, auto dim,... CPU ↓10-15%.</string>
            <key>PayloadIdentifier</key>
            <string>com.performance.ios.v12.restrict1</string>
            <key>PayloadType</key>
            <string>com.apple.applicationaccess</string>
            <key>PayloadUUID</key>
            <string>b0c1d2e3-f4a5-6789-abcd-0000000000b2</string>
            <key>PayloadVersion</key>
            <integer>1</integer>
            <key>Restrictions</key>
            <dict>
            <key>allowDiagnosticSubmission</key><false/>
            <key>allowAutomaticAppDownloads</key><false/>
            <key>allowAssistant</key><false/>
            <key>allowSpotlightSuggestions</key><false/>
            <key>allowOTAPKIUpdates</key><false/>
            <key>allowAppStoreAppAdTracking</key><false/>
            <key>allowApplePersonalizedAdvertising</key><false/>
            <key>allowActivityContinuation</key><false/>
            <key>allowGameCenter</key><false/>
            <key>allowGameCenterFriendsDiscovery</key><false/>
            <key>allowAppClips</key><false/>
            <key>allowVoiceDialing</key><false/>
            <key>allowPassbookWhileLocked</key><false/>
            <key>allowAppleIntelligence</key><false/>
            <key>allowWritingTools</key><false/>
            <key>allowExternalIntelligenceIntegrations</key><false/>
            <key>allowAppleIntelligenceReport</key><false/>
                <key>allowAppInstallation</key><true/>
                <key>allowScreenShot</key><true/>
                <key>allowBluetoothModification</key><true/>
            </dict>
        </dict>
        <dict>
            <key>PayloadDisplayName</key>
            <string>Restriction B — iCloud &amp; Network</string>
            <key>PayloadDescription</key>
            <string>15 restriction: iCloud Drive, backup, keychain + 7 sync services, AirDrop, Handoff, Find Friends, Mail Drop. RAM ↑50-100MB.</string>
            <key>PayloadIdentifier</key>
            <string>com.performance.ios.v12.restrict2</string>
            <key>PayloadType</key>
            <string>com.apple.applicationaccess</string>
            <key>PayloadUUID</key>
            <string>b0c1d2e3-f4a5-6789-abcd-0000000000b3</string>
            <key>PayloadVersion</key>
            <integer>1</integer>
            <key>Restrictions</key>
            <dict>
            <key>allowCloudDocumentSync</key><false/>
            <key>allowCloudBackup</key><false/>
            <key>allowCloudKeychainSync</key><false/>
            <key>allowCloudAddressBookSync</key><false/>
            <key>allowCloudCalendarSync</key><false/>
